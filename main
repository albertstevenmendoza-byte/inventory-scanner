<script>
// ── State ─────────────────────────────────────────────────────────────────────
const STEPS = ['hu', 'material', 'batch'];
let currentStep = 0;   // 0=HU, 1=Material, 2=Batch
let scanData    = { hu: null, material: null, batch: null };
let sessionLog  = [];
let sessionCount = 0;
let scanning    = false;
let videoStream = null;
let scanInterval = null;
let lastDecoded = null;
let lastDecodedTime = 0;
const COOLDOWN  = 2000; // ms before same barcode fires again

// ── Camera Setup ──────────────────────────────────────────────────────────────
async function startCamera() {
  const video = document.getElementById('video');
  try {
    videoStream = await navigator.mediaDevices.getUserMedia({
      video: {
        facingMode: 'environment',  // rear camera
        width:  { ideal: 1280 },
        height: { ideal: 720 }
      },
      audio: false
    });
    video.srcObject = videoStream;
    video.play();
    video.addEventListener('loadedmetadata', () => {
      startDecoding();
    });
  } catch (err) {
    document.getElementById('camStatusText').textContent = 'NO CAM';
    showToast('Camera access denied — check browser permissions');
  }
}

// ── Barcode Decoding (ZXing) ──────────────────────────────────────────────────
let codeReader = null;

function startDecoding() {
  const video  = document.getElementById('video');
  const canvas = document.getElementById('canvas');
  const ctx    = canvas.getContext('2d');

  // Use ZXing if available, else fallback to BarcodeDetector
  if (typeof ZXing !== 'undefined') {
    const hints = new Map();
    const formats = [
      ZXing.BarcodeFormat.CODE_128,
      ZXing.BarcodeFormat.CODE_39,
      ZXing.BarcodeFormat.EAN_13,
      ZXing.BarcodeFormat.UPC_A,
      ZXing.BarcodeFormat.QR_CODE,
      ZXing.BarcodeFormat.DATA_MATRIX,
    ];
    hints.set(ZXing.DecodeHintType.POSSIBLE_FORMATS, formats);
    hints.set(ZXing.DecodeHintType.TRY_HARDER, true);

    codeReader = new ZXing.MultiFormatReader();
    codeReader.setHints(hints);

    scanInterval = setInterval(() => {
      if (!video.videoWidth) return;
      canvas.width  = video.videoWidth;
      canvas.height = video.videoHeight;
      ctx.drawImage(video, 0, 0);
      try {
        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const luminanceSource = new ZXing.RGBLuminanceSource(imageData.data, canvas.width, canvas.height);
        const binaryBitmap    = new ZXing.BinaryBitmap(new ZXing.HybridBinarizer(luminanceSource));
        const result          = codeReader.decode(binaryBitmap);
        if (result) onBarcodeDetected(result.getText());
      } catch (e) { /* no barcode in frame */ }
    }, 150);

  } else if ('BarcodeDetector' in window) {
    // Native BarcodeDetector API (Chrome Android)
    const detector = new BarcodeDetector({
      formats: ['code_128', 'code_39', 'ean_13', 'upc_a', 'qr_code', 'data_matrix']
    });
    scanInterval = setInterval(async () => {
      if (!video.videoWidth) return;
      canvas.width  = video.videoWidth;
      canvas.height = video.videoHeight;
      ctx.drawImage(video, 0, 0);
      try {
        const barcodes = await detector.detect(canvas);
        if (barcodes.length > 0) onBarcodeDetected(barcodes[0].rawValue);
      } catch (e) {}
    }, 200);
  } else {
    showToast('Barcode detection not supported on this browser');
  }

  scanning = true;
  updateMainBtn();
}

// ── On Barcode Detected ───────────────────────────────────────────────────────
function onBarcodeDetected(value) {
  const now = Date.now();
  if (value === lastDecoded && now - lastDecodedTime < COOLDOWN) return;
  lastDecoded     = value;
  lastDecodedTime = now;

  // Vibrate
  if (navigator.vibrate) navigator.vibrate(60);

  recordScan(value);
}

// ── Record Scan ───────────────────────────────────────────────────────────────
function recordScan(value) {
  const key       = STEPS[currentStep];
  scanData[key]   = value;
  const timestamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });

  // Update card
  const cardIndex = currentStep + 1;
  const valEl     = document.getElementById(`val${cardIndex}`);
  const badgeEl   = document.getElementById(`badge${cardIndex}`);
  const metaEl    = document.getElementById(`meta${cardIndex}`);
  const cardEl    = document.getElementById(`card${cardIndex}`);

  valEl.textContent   = value;
  valEl.className     = 'card-value';
  badgeEl.textContent = '✓ Scanned';
  badgeEl.className   = 'card-badge badge-scanned';
  metaEl.textContent  = timestamp;
  cardEl.classList.add('pulse');
  setTimeout(() => cardEl.classList.remove('pulse'), 400);

  // Update step pill
  const pillEl  = document.getElementById(`step${cardIndex}pill`);
  const lblEl   = document.getElementById(`step${cardIndex}label`);
  pillEl.className  = 'step-pill done';
  lblEl.className   = 'step-label done';

  // Advance
  currentStep++;
  if (currentStep < 3) {
    updateInstruction();
    updateStepActive();
  } else {
    // All done
    completeScan();
  }

  scrollToBottom();
}

// ── Complete Scan ─────────────────────────────────────────────────────────────
function completeScan() {
  sessionCount++;
  document.getElementById('sessionCount').textContent = sessionCount;

  const entry = {
    hu:        scanData.hu       || '—',
    material:  scanData.material || '—',
    batch:     scanData.batch    || '—',
    time:      new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' }),
    date:      new Date().toLocaleDateString()
  };

  sessionLog.unshift(entry);

  // Update instruction
  const instrCard = document.getElementById('instrCard');
  instrCard.querySelector('.instr-title').textContent = '✓ Scan Complete';
  instrCard.querySelector('.instr-desc').textContent  = 'All barcodes captured. Tap "Save & Next" to log this item and start a new scan.';
  instrCard.querySelector('.instr-icon').textContent  = '✅';
  instrCard.className = 'instruction active';

  // Update button
  document.getElementById('mainBtn').textContent = 'Save & Next';
  document.getElementById('skipBtn').style.display = 'none';

  if (navigator.vibrate) navigator.vibrate([60, 40, 120]);
  showToast('All 3 barcodes captured!');
}

// ── Reset / New Scan ──────────────────────────────────────────────────────────
function resetScan() {
  currentStep = 0;
  scanData    = { hu: null, material: null, batch: null };
  lastDecoded = null;

  // Reset cards
  [1,2,3].forEach(i => {
    document.getElementById(`val${i}`).textContent   = '— not yet scanned —';
    document.getElementById(`val${i}`).className     = 'card-value empty';
    document.getElementById(`badge${i}`).textContent = 'Waiting';
    document.getElementById(`badge${i}`).className   = 'card-badge badge-waiting';
    document.getElementById(`meta${i}`).textContent  = '';
    document.getElementById(`card${i}`).className    = 'result-card pending';
  });

  // Reset steps
  [1,2,3].forEach(i => {
    document.getElementById(`step${i}pill`).className  = 'step-pill';
    document.getElementById(`step${i}label`).className = 'step-label';
  });
  document.getElementById('step1pill').className  = 'step-pill active';
  document.getElementById('step1label').className = 'step-label active';

  // Reset instruction
  document.getElementById('instrCard').querySelector('.instr-title').textContent = 'Scan HU Number';
  document.getElementById('instrCard').querySelector('.instr-desc').textContent  = 'Point camera at the top barcode on the label — the HU Number.';
  document.getElementById('instrCard').querySelector('.instr-icon').textContent  = '📦';

  // Reset buttons
  document.getElementById('mainBtn').textContent       = 'Scanning…';
  document.getElementById('skipBtn').style.display     = '';

  document.getElementById('scrollArea').scrollTop = 0;
}

// ── Skip Current Step ─────────────────────────────────────────────────────────
function skipCurrent() {
  if (currentStep >= 3) return;

  const key       = STEPS[currentStep];
  scanData[key]   = null;

  const cardIndex = currentStep + 1;
  const valEl     = document.getElementById(`val${cardIndex}`);
  const badgeEl   = document.getElementById(`badge${cardIndex}`);
  const pillEl    = document.getElementById(`step${cardIndex}pill`);
  const lblEl     = document.getElementById(`step${cardIndex}label`);

  valEl.textContent   = '— skipped —';
  valEl.className     = 'card-value empty';
  badgeEl.textContent = 'Skipped';
  badgeEl.className   = 'card-badge badge-skipped';
  pillEl.className    = 'step-pill skip';
  lblEl.className     = 'step-label';

  currentStep++;
  if (currentStep < 3) {
    updateInstruction();
    updateStepActive();
  } else {
    completeScan();
  }

  scrollToBottom();
}

// ── Main Button ───────────────────────────────────────────────────────────────
function handleMainBtn() {
  if (currentStep >= 3) {
    // Save & reset
    addToLog(sessionLog[0]);
    resetScan();
    showToast('Saved to log ✓');
  }
}

// ── Instruction Update ────────────────────────────────────────────────────────
const instrMap = [
  { icon: '📦', title: 'Scan HU Number',       desc: 'Point camera at the top barcode on the label — the HU Number.' },
  { icon: '🏷',  title: 'Scan Material Number', desc: 'Now scan the second barcode — the Material Number.' },
  { icon: '🔢', title: 'Scan Batch Number',     desc: 'Finally, scan the third barcode — the Batch or Invoice Number. Tap Skip if not present.' },
];

function updateInstruction() {
  if (currentStep >= 3) return;
  const m = instrMap[currentStep];
  document.getElementById('instrCard').querySelector('.instr-icon').textContent  = m.icon;
  document.getElementById('instrCard').querySelector('.instr-title').textContent = m.title;
  document.getElementById('instrCard').querySelector('.instr-desc').textContent  = m.desc;
}

function updateStepActive() {
  [1,2,3].forEach(i => {
    const pill = document.getElementById(`step${i}pill`);
    const lbl  = document.getElementById(`step${i}label`);
    if (pill.className === 'step-pill' && i === currentStep + 1) {
      pill.className = 'step-pill active';
      lbl.className  = 'step-label active';
    }
  });
}

function updateMainBtn() {
  document.getElementById('mainBtn').textContent = currentStep < 3 ? 'Scanning…' : 'Save & Next';
}

// ── Log ───────────────────────────────────────────────────────────────────────
function addToLog(entry) {
  const scroll  = document.getElementById('logScroll');
  const empty   = document.getElementById('logEmpty');
  if (empty) empty.remove();

  const div = document.createElement('div');
  div.className = 'log-entry';
  div.innerHTML = `
    <div class="log-entry-top">
      <div class="log-entry-hu">${entry.hu}</div>
      <div class="log-entry-time">${entry.time}</div>
    </div>
    <div class="log-entry-details">
      <div class="log-detail"><span class="log-detail-label">Material: </span><span class="log-detail-value">${entry.material}</span></div>
      <div class="log-detail"><span class="log-detail-label">Batch: </span><span class="log-detail-value">${entry.batch}</span></div>
      <div class="log-detail"><span class="log-detail-label">Date: </span><span class="log-detail-value">${entry.date}</span></div>
    </div>
  `;
  scroll.insertBefore(div, scroll.firstChild);
}

function showLog() {
  document.getElementById('scannerView').style.display = 'none';
  document.getElementById('logView').classList.add('visible');

  // Rebuild log
  const scroll = document.getElementById('logScroll');
  scroll.innerHTML = '';
  if (sessionLog.length === 0) {
    scroll.innerHTML = '<div class="log-empty" id="logEmpty">No scans logged yet</div>';
    return;
  }
  sessionLog.forEach(e => addToLogView(e, scroll));
}

function addToLogView(entry, scroll) {
  const div = document.createElement('div');
  div.className = 'log-entry';
  div.innerHTML = `
    <div class="log-entry-top">
      <div class="log-entry-hu">${entry.hu}</div>
      <div class="log-entry-time">${entry.time}</div>
    </div>
    <div class="log-entry-details">
      <div class="log-detail"><span class="log-detail-label">Material: </span><span class="log-detail-value">${entry.material}</span></div>
      <div class="log-detail"><span class="log-detail-label">Batch: </span><span class="log-detail-value">${entry.batch}</span></div>
      <div class="log-detail"><span class="log-detail-label">Date: </span><span class="log-detail-value">${entry.date}</span></div>
    </div>
  `;
  scroll.appendChild(div);
}

function hideLog() {
  document.getElementById('logView').classList.remove('visible');
  document.getElementById('scannerView').style.display = 'flex';
}

function clearLog() {
  sessionLog = [];
  sessionCount = 0;
  document.getElementById('sessionCount').textContent = 0;
  document.getElementById('logScroll').innerHTML = '<div class="log-empty" id="logEmpty">No scans logged yet</div>';
  showToast('Log cleared');
}

function exportLog() {
  if (sessionLog.length === 0) { showToast('No data to export'); return; }

  const header = 'HU Number,Material Number,Batch Number,Time,Date\n';
  const rows   = sessionLog.map(e =>
    `${e.hu},${e.material},${e.batch},${e.time},${e.date}`
  ).join('\n');

  const blob = new Blob([header + rows], { type: 'text/csv' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = `novus_scan_log_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
  showToast('Exported as CSV ✓');
}

// ── Toast ─────────────────────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

// ── Scroll Helper ─────────────────────────────────────────────────────────────
function scrollToBottom() {
  const area = document.getElementById('scrollArea');
  setTimeout(() => area.scrollTo({ top: area.scrollHeight, behavior: 'smooth' }), 100);
}

// ── Init ──────────────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  startCamera();
});
</script>
</body>
</html>
